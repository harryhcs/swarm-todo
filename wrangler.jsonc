{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "swarm-todo",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-08-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "swarm-todo",
      "database_id": "__change_me__"
    }
  ],
  "vars": {}
}

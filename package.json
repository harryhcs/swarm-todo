{
  "name": "swarm-todo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "deploy": "bun run build && wrangler deploy",
    "generate": "wrangler types --include-runtime false",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "migrate:remote": "wrangler d1 migrations apply DB --remote",
    "drizzle:generate": "drizzle-kit generate",
    "clean": "rm -rf ./node_modules/.vite"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-server-dom-webpack": "19.1.0",
    "rwsdk": "^1.2.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.0",
    "@cloudflare/workers-types": "^4.20260426.0",
    "@eslint/js": "^9.0.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "wrangler": "^4.0.0"
  }
}
